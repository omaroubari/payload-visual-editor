{
  "extends": "../tsconfig.json",
  "exclude": [],
  "include": [
    "access/**/*.ts",
    "app/**/*.ts",
    "app/**/*.tsx",
    "app/**/*.js",
    "collections/**/*.ts",
    "blocks/CallToAction/config.ts",
    "blocks/Content/config.ts",
    "blocks/FAQs/config.ts",
    "blocks/Features/config.ts",
    "blocks/MediaBlock/config.ts",
    "blocks/Testimonials/config.ts",
    "components/**/*.ts",
    "components/**/*.tsx",
    "e2e.spec.ts",
    "fields/**/*.ts",
    "fields/**/*.tsx",
    "helpers/**/*.ts",
    "heros/config.ts",
    "heros/HighImpact/**/*.tsx",
    "heros/RenderHero.tsx",
    "hooks/**/*.ts",
    "int.spec.ts",
    "lib/**/*.ts",
    "payload-types.ts",
    "payload.config.ts",
    "seed.ts",
    "utilities/deepMerge.ts",
    "utilities/generatePreviewPath.ts",
    "utilities/getMediaUrl.ts",
    "utilities/toKebabCase.ts",
    "../src/**/*.ts",
    "../src/**/*.tsx",
    "next.config.mjs",
    ".next/types/**/*.ts",
  ],
  "compilerOptions": {
    "baseUrl": "./",
    "composite": false,
    "declaration": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./*"],
      "dev/*": ["./*"],
      "@payload-config": ["./payload.config.ts"],
      "payload-visual-editor": ["../src/index.ts"],
      "payload-visual-editor/client": ["../src/exports/client.ts"],
      "payload-visual-editor/rsc": ["../src/exports/rsc.ts"],
    },
    "noEmit": true,
    "emitDeclarationOnly": false,
  },
}
